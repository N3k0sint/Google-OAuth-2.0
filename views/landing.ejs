<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Secure SSO</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(120deg, #E0C3FC 0%, #8EC5FC 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .dashboard-card {
            background: rgba(255, 255, 255, 0.95);
            padding: 3rem;
            border-radius: 24px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            text-align: center;
            width: 85%;
            max-width: 500px;
        }

        .profile-container {
            position: relative;
            display: inline-block;
            margin-bottom: 1.5rem;
        }

        .profile-img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 4px solid white;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .status-badge {
            position: absolute;
            bottom: 5px;
            right: 5px;
            background: #10B981;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            border: 3px solid white;
        }

        h2 {
            color: #1f2937;
            margin: 0.5rem 0;
            font-size: 1.8rem;
        }

        .email-pill {
            background: #f3f4f6;
            color: #4b5563;
            padding: 0.5rem 1rem;
            border-radius: 999px;
            font-size: 0.95rem;
            display: inline-block;
            margin-bottom: 2rem;
            font-weight: 500;
        }

        .security-context {
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 2rem;
            text-align: left;
        }

        .context-item {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            color: #1e3a8a;
            margin: 4px 0;
        }

        .context-label {
            font-weight: 600;
            color: #3b82f6;
        }

        .btn-logout {
            display: block;
            width: 100%;
            background: #ef4444;
            color: white;
            text-decoration: none;
            padding: 14px 0;
            border-radius: 12px;
            font-weight: 600;
            transition: background 0.2s;
        }

        .btn-logout:hover {
            background: #dc2626;
        }
    </style>
</head>

<body>
    <div class="dashboard-card">
        <div class="profile-container">
            <% if (user.photos && user.photos.length> 0) { %>
                <img src="<%= user.photos[0].value %>" alt="Profile" class="profile-img" referrerpolicy="no-referrer">
                <% } else { %>
                    <div class="profile-img"
                        style="background:#ddd;display:flex;align-items:center;justify-content:center;font-size:2rem;">
                        👤</div>
                    <% } %>
                        <div class="status-badge" title="Active Session"></div>
        </div>

        <h2>
            <%= user.displayName %>
        </h2>
        <div class="email-pill">
            <%= user.emails && user.emails.length> 0 ? user.emails[0].value : 'No email' %>
        </div>

        <div class="security-context">
            <div class="context-item">
                <span class="context-label">Identity Provider</span>
                <span>
                    <%= user.provider ? user.provider.charAt(0).toUpperCase() + user.provider.slice(1) : 'Google OAauth'
                        %>
                </span>
            </div>
            <div class="context-item">
                <span class="context-label">Authentication</span>
                <span>OAuth 2.0 / OIDC</span>
            </div>
            <div class="context-item">
                <span class="context-label">Session Status</span>
                <span style="color:#10B981; font-weight:bold;">● Active</span>
            </div>
        </div>

        <a href="/logout" class="btn-logout">Sign Out</a>
    </div>
</body>

</html>
